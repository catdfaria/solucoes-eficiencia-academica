{
    "apiVersion": "2019-05-01",
    "id": "/subscriptions/<YOUR_SUBSCRIPTION_ID>/resourceGroups/<YOUR_RESOURCE_GROUP>/providers/Microsoft.Logic/workflows/BenzaBot-Processamento-Forms",
    "name": "BenzaBot-Processamento-Forms",
    "type": "microsoft.logic/workflows",
    "location": "brazilsouth",
    "properties": {
        "state": "Enabled",
        "accessEndpoint": "https://<YOUR_LOGIC_APP_ENDPOINT>",
        "definition": {
            "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
            "actions": {
                "HTTP": {
                    "type": "Http",
                    "inputs": {
                        "uri": "https://benzabotnovo.azurewebsites.net/api/EstilizarResposta?code=<YOUR_FUNCTION_KEY>",
                        "method": "POST",
                        "headers": { "Content-Type": "application/json" },
                        "body": {
                            "protocolo": "@triggerBody()?['protocolo']",
                            "pergunta": "@triggerBody()?['pergunta']",
                            "tags": "@triggerBody()?['tags']",
                            "equipe": "@triggerBody()?['equipe']",
                            "sazonalidade": "@triggerBody()?['sazonalidade']",
                            "tom": "@triggerBody()?['tom']",
                            "cache_argumentos": "@body('Listar_linhas_presentes_em_uma_tabela')?['value']"
                        }
                    }
                },
                "Switch": {
                    "cases": {
                        "Educacao_Continuada": {
                            "case": "EDUCACAO_CONTINUADA",
                            "actions": {
                                "Adicionar_uma_linha": {
                                    "type": "ApiConnection",
                                    "inputs": {
                                        "body": {
                                            "RESPOSTA ESTILIZADA": "@body('Parse_JSON')?['respostaEstilizada']",
                                            "HASH": "@body('Parse_JSON')?['hash']",
                                            "DATA/HORA": "@{convertFromUtc(utcNow(), 'E. South America Standard Time', 'dd/MM/yyyy HH:mm:ss')}"
                                        },
                                        "path": "/codeless/v1.2/drives/me/items/<EXCEL_FILE_ID>/workbook/tables/<TABLE_ID>/rows"
                                    }
                                }
                            }
                        }
                    },
                    "expression": "@triggerBody()?['equipe']",
                    "type": "Switch"
                }
            }
        },
        "parameters": {
            "$connections": {
                "value": {
                    "excelonline-1": {
                        "id": "/subscriptions/<YOUR_SUBSCRIPTION_ID>/providers/Microsoft.Web/locations/brazilsouth/managedApis/excelonline",
                        "connectionId": "/subscriptions/<YOUR_SUBSCRIPTION_ID>/resourceGroups/<YOUR_RESOURCE_GROUP>/providers/Microsoft.Web/connections/excelonline-shared"
                    }
                }
            }
        }
    }
}
